# NKS osTicket MCP server configuration

# Base URL of the NKS osTicket API entry point (required)
NKS_OSTICKET_URL=https://support.example.com/api/nks-osticket.php

# osTicket API key, bound to this client's source IP (required)
NKS_OSTICKET_API_KEY=your-osticket-api-key

# Request timeout in milliseconds (optional, default 30000)
NKS_OSTICKET_TIMEOUT_MS=30000

# Set to "false" to allow self-signed TLS certificates (optional, default true)
NKS_OSTICKET_REJECT_UNAUTHORIZED=true
