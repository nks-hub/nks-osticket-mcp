{
  "name": "@nks-hub/osticket-mcp",
  "version": "1.0.0",
  "description": "MCP server for osTicket — list, search, get, create, update, reply, delete tickets plus stats, statuses, subtickets and attachments, over a single JSON API.",
  "type": "module",
  "bin": {
    "nks-osticket-mcp": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "osticket",
    "helpdesk",
    "tickets",
    "ai-agent"
  ],
  "author": "NKS",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
